<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/light_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/dark_slate"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_md">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Challenge Board" android:textColor="@color/white"
            android:textSize="18sp" android:textStyle="bold" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPostChallenge"
            style="@style/KreedaButtonOutlined"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Post +"
            android:textColor="@color/white"
            android:strokeColor="@color/white" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvLiveLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔴 LIVE"
        android:textColor="@color/error_red"
        android:textStyle="bold"
        android:textSize="12sp"
        android:padding="@dimen/spacing_md" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChallenges"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/spacing_md"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/tvNoChallenges"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No challenges posted yet"
        android:textColor="@color/text_hint"
        android:gravity="center"
        android:padding="@dimen/spacing_xl"
        android:visibility="gone" />
</LinearLayout>
