<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email (Read Only)"
            android:textColor="@color/dark_slate"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etEditEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:background="@drawable/edit_text_border"
            android:textColor="@color/text_hint"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone (Read Only)"
            android:textColor="@color/dark_slate"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etEditPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:background="@drawable/edit_text_border"
            android:textColor="@color/text_hint"
            android:inputType="phone"
            android:layout_marginBottom="16dp" />

        <!-- Sport Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Sport"
            android:textStyle="bold"
            android:textColor="@color/dark_slate"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupProfileSports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="false"
            app:selectionRequired="false"
            android:layout_marginBottom="16dp" />

        <!-- Team Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Team"
            android:textStyle="bold"
            android:textColor="@color/dark_slate"
            android:textSize="14sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvSelectTeam"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="-- Select Team --"
            android:textColor="@color/black"
            android:textSize="13sp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:background="@drawable/edit_text_border"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>
