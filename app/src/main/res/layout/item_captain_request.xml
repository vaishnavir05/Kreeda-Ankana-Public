<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@color/white">

    <TextView
        android:id="@+id/tvRequestUserName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="User requests Captain"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnApproveRequest"
        android:layout_width="72dp"
        android:layout_height="36dp"
        android:text="Approve"
        android:textSize="11sp"
        android:backgroundTint="@color/mint_green"
        android:textColor="@color/dark_slate"
        android:layout_marginEnd="6dp" />

    <Button
        android:id="@+id/btnRejectRequest"
        android:layout_width="60dp"
        android:layout_height="36dp"
        android:text="Reject"
        android:textSize="11sp"
        android:backgroundTint="@color/status_declined"
        android:textColor="@color/error_red" />
</LinearLayout>
