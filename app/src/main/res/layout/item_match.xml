<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    style="@style/KreedaCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvMatchTeams"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Team A vs Team B"
            android:textStyle="bold"
            android:textColor="@color/dark_slate"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvMatchSport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cricket"
                android:textColor="@color/dark_slate"
                android:textSize="12sp"
                android:background="@color/mint_green"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp"
                android:minWidth="110dp"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvMatchStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCHEDULED"
                android:textColor="@color/dark_slate"
                android:textSize="12sp"
                android:background="@color/pastel_yellow"
                android:paddingHorizontal="16dp"
                android:paddingVertical="4dp"
                android:minWidth="110dp"
                android:gravity="center" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvMatchGround"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ground Name"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvMatchDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12 May 2026, 10:00 AM"
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
