<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    style="@style/KreedaCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/mint_green"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBookingGround"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ground Name"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvBookingTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00 AM – 11:00 AM"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="4dp">
 
                <TextView
                    android:id="@+id/tvBookingSport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cricket"
                    android:textColor="@color/dark_slate"
                    android:textSize="12sp"
                    android:background="@color/mint_green"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"
                    android:minWidth="110dp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp" />
 
                <TextView
                    android:id="@+id/tvBookingType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRACTICE"
                    android:textColor="@color/dark_slate"
                    android:textSize="12sp"
                    android:background="@color/pastel_yellow"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"
                    android:minWidth="110dp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvBookingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONFIRMED"
            android:textColor="@color/success_green"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
