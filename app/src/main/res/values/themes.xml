<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.KreedaAnkana" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/dark_slate</item>
        <item name="colorPrimaryVariant">@color/dark_slate_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/mint_green</item>
        <item name="colorSecondaryVariant">@color/mint_green</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:colorBackground">@color/light_background</item>
        <item name="android:statusBarColor">@color/dark_slate</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Card Style -->
    <style name="KreedaCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">3dp</item>
        <item name="cardBackgroundColor">@color/card_surface</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Input Fields -->
    <style name="KreedaInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@android:color/transparent</item>
        <item name="boxStrokeColor">@color/black</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/black</item>
        <item name="materialThemeOverlay">@style/KreedaInputTheme</item>
    </style>

    <style name="KreedaInputTheme">
        <item name="editTextColor">#000000</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textColorHint">@color/black</item>
        <item name="colorControlNormal">@color/black</item>
        <item name="colorControlActivated">@color/black</item>
        <item name="colorPrimary">@color/black</item>
    </style>

    <!-- Primary Button -->
    <style name="KreedaButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/dark_slate</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Secondary Button -->
    <style name="KreedaButtonOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/dark_slate</item>
        <item name="android:textColor">@color/dark_slate</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Chip Style -->
    <style name="KreedaChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/mint_green</item>
        <item name="android:textColor">@color/dark_slate</item>
        <item name="chipCornerRadius">20dp</item>
    </style>

    <!-- Section Header -->
    <style name="SectionHeader">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <!-- Body Text -->
    <style name="BodyText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- Toolbar -->
    <style name="KreedaToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/dark_slate</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
    </style>
</resources>
