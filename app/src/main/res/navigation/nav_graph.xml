<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Auth -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.kreedaankana.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_signup"
            app:destination="@id/signupFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="false" />
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/signupFragment"
        android:name="com.example.kreedaankana.ui.auth.SignupFragment"
        android:label="Sign Up"
        tools:layout="@layout/fragment_signup">
        <action
            android:id="@+id/action_signup_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_signup_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Main sections (bottom nav) -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.kreedaankana.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_booking"
            app:destination="@id/bookingFragment" />
        <action
            android:id="@+id/action_home_to_groundList"
            app:destination="@id/groundListFragment" />
        <action
            android:id="@+id/action_home_to_allBookings"
            app:destination="@id/allBookingsFragment" />
        <action
            android:id="@+id/action_home_to_scoreWall"
            app:destination="@id/scoreWallFragment" />
    </fragment>

    <fragment
        android:id="@+id/groundListFragment"
        android:name="com.example.kreedaankana.ui.grounds.GroundListFragment"
        android:label="Grounds"
        tools:layout="@layout/fragment_ground_list">
        <action
            android:id="@+id/action_groundList_to_groundDetail"
            app:destination="@id/groundDetailFragment" />
        <action
            android:id="@+id/action_groundList_to_addEntity"
            app:destination="@id/addEntityFragment" />
    </fragment>

    <fragment
        android:id="@+id/groundDetailFragment"
        android:name="com.example.kreedaankana.ui.grounds.GroundDetailFragment"
        android:label="Ground Details"
        tools:layout="@layout/fragment_ground_detail">
        <argument
            android:name="groundId"
            app:argType="integer" />
        <action
            android:id="@+id/action_groundDetail_to_booking"
            app:destination="@id/bookingFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingFragment"
        android:name="com.example.kreedaankana.ui.booking.BookingFragment"
        android:label="Book Slot"
        tools:layout="@layout/fragment_booking" />

    <fragment
        android:id="@+id/teamFragment"
        android:name="com.example.kreedaankana.ui.team.TeamFragment"
        android:label="Teams"
        tools:layout="@layout/fragment_team">
        <action
            android:id="@+id/action_team_to_addEntity"
            app:destination="@id/addEntityFragment" />
    </fragment>

    <fragment
        android:id="@+id/challengeBoardFragment"
        android:name="com.example.kreedaankana.ui.challenge.ChallengeBoardFragment"
        android:label="Challenge Board"
        tools:layout="@layout/fragment_challenge_board">
        <action
            android:id="@+id/action_board_to_createChallenge"
            app:destination="@id/createChallengeFragment" />
    </fragment>

    <fragment
        android:id="@+id/createChallengeFragment"
        android:name="com.example.kreedaankana.ui.challenge.CreateChallengeFragment"
        android:label="Post Challenge"
        tools:layout="@layout/fragment_create_challenge" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.kreedaankana.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profile_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_profile_to_admin"
            app:destination="@id/adminDashboardFragment" />
        <action
            android:id="@+id/action_profile_to_addEntity"
            app:destination="@id/addEntityFragment" />
    </fragment>

    <fragment
        android:id="@+id/matchDetailFragment"
        android:name="com.example.kreedaankana.ui.match.MatchDetailFragment"
        android:label="Match Details"
        tools:layout="@layout/fragment_match_detail">
        <argument
            android:name="matchId"
            app:argType="integer" />
        <action
            android:id="@+id/action_matchDetail_to_scoreUpdate"
            app:destination="@id/scoreUpdateFragment" />
    </fragment>

    <fragment
        android:id="@+id/scoreUpdateFragment"
        android:name="com.example.kreedaankana.ui.match.ScoreUpdateFragment"
        android:label="Update Score"
        tools:layout="@layout/fragment_score_update">
        <argument
            android:name="matchId"
            app:argType="integer" />
        <argument
            android:name="sport"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/adminDashboardFragment"
        android:name="com.example.kreedaankana.ui.admin.AdminDashboardFragment"
        android:label="Admin Dashboard"
        tools:layout="@layout/fragment_admin_dashboard">
        <action
            android:id="@+id/action_admin_to_addEntity"
            app:destination="@id/addEntityFragment" />
    </fragment>

    <fragment
        android:id="@+id/addEntityFragment"
        android:name="com.example.kreedaankana.ui.management.AddEntityFragment"
        android:label="Management"
        tools:layout="@layout/fragment_add_entity" />

    <fragment
        android:id="@+id/scoreWallFragment"
        android:name="com.example.kreedaankana.ui.match.ScoreWallFragment"
        android:label="Score Wall"
        tools:layout="@layout/fragment_score_wall" />

    <fragment
        android:id="@+id/allBookingsFragment"
        android:name="com.example.kreedaankana.ui.home.AllBookingsFragment"
        android:label="All Bookings"
        tools:layout="@layout/fragment_all_bookings" />

</navigation>
